# ─────────────────────────────────────────────────────────────────────
#  AI SDLC Assistant — Environment Variables
#  Copy this file to .env and fill in your actual keys
#  NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────

# ── LLM Provider: Groq (free tier at https://console.groq.com)
GROQ_API_KEY=gsk_placeholder_replace_with_your_key
GROQ_MODEL=llama-3.3-70b-versatile

# ── LangSmith Observability (free tier at https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_placeholder_replace_with_your_key
LANGCHAIN_PROJECT=ai-sdlc-assistant
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Vector Database — Qdrant (runs in Docker, no key needed for local)
QDRANT_URL=
QDRANT_COLLECTION=sdlc_knowledge

# ── Cache — Redis (runs in Docker, no key needed for local)
REDIS_URL=
REDIS_TTL_SECONDS=3600

# ── External Tool Integrations (MCP Connectors)
# GitHub: create token at https://github.com/settings/tokens
# Scopes needed: repo, read:org
GITHUB_TOKEN=ghp_placeholder_replace_with_your_token
GITHUB_REPO=your-org/your-repo

# Jira: create API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=placeholder_replace_with_your_jira_token
JIRA_PROJECT_KEY=SDLC

# Slack: create app at https://api.slack.com/apps (use mock=true to skip)
SLACK_BOT_TOKEN=xoxb_placeholder_replace_with_your_token
SLACK_USE_MOCK=true        # true = use local JSON mock data (safe for demo)

# ── Application Settings
APP_SECRET_KEY=change_this_to_a_random_secret_string_in_production
APP_ENV=development         # development | production
LOG_LEVEL=INFO

# ── Demo Users (role-based auth without OAuth — for demo only)
# These tokens are used as simple Bearer tokens in the Chainlit UI
# Format: TOKEN=role:project
DEMO_TOKEN_DEVELOPER=dev_token_alice
DEMO_TOKEN_MANAGER=manager_token_bob
DEMO_TOKEN_STAKEHOLDER=stakeholder_token_client

# ── Default Project for Demo
DEFAULT_PROJECT=antlog
